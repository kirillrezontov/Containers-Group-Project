{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C/C++ all",
      "type": "cppdbg",                // ← обязательно cppdbg
      "request": "launch",
      "program": "${workspaceFolder}/main.exe",   // бинарник в WSL
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",       // gdb внутри WSL
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build main all file",
    },
    {
      "name": "C/C++ one or more",
      "type": "cppdbg",                // ← обязательно cppdbg
      "request": "launch",
      "program": "${workspaceFolder}/main.exe",   // бинарник в WSL
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",       // gdb внутри WSL
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build main one or more file",
    }
  ]
}
